// Shadow Kingdom Prisma Schema
// This schema matches the existing SQLite database structure

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Game {
  id           Int       @id @default(autoincrement())
  name         String    @unique
  createdAt    DateTime  @default(now()) @map("created_at")
  lastPlayedAt DateTime  @default(now()) @map("last_played_at")
  
  rooms        Room[]
  connections  Connection[]
  gameState    GameState?
  regions      Region[]
  characters   Character[]
  
  @@map("games")
}

model Room {
  id             Int     @id @default(autoincrement())
  gameId         Int     @map("game_id")
  name           String
  description    String
  regionId       Int?    @map("region_id")
  regionDistance Int?    @map("region_distance")
  
  game           Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  region         Region? @relation(fields: [regionId], references: [id])
  
  connectionsFrom Connection[] @relation("FromRoom")
  connectionsTo   Connection[] @relation("ToRoom")
  gameStates      GameState[]
  roomItems       RoomItem[]
  
  @@index([gameId])
  @@index([regionId])
  @@map("rooms")
}

model Connection {
  id         Int     @id @default(autoincrement())
  gameId     Int     @map("game_id")
  fromRoomId Int     @map("from_room_id")
  toRoomId   Int?    @map("to_room_id")
  direction  String?
  name       String
  processing Boolean @default(false)
  
  game       Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  fromRoom   Room    @relation("FromRoom", fields: [fromRoomId], references: [id])
  toRoom     Room?   @relation("ToRoom", fields: [toRoomId], references: [id])
  
  @@index([gameId])
  @@index([fromRoomId, direction, name])
  @@index([gameId, fromRoomId])
  @@index([gameId, fromRoomId, processing])
  @@map("connections")
}

model GameState {
  id            Int    @id @default(autoincrement())
  gameId        Int    @unique @map("game_id")
  currentRoomId Int    @map("current_room_id")
  playerName    String? @map("player_name")
  
  game          Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  currentRoom   Room   @relation(fields: [currentRoomId], references: [id])
  
  @@map("game_state")
}

model Region {
  id           Int      @id @default(autoincrement())
  gameId       Int      @map("game_id")
  name         String?
  type         String
  description  String
  centerRoomId Int?     @map("center_room_id")
  createdAt    DateTime @default(now()) @map("created_at")
  
  game         Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  rooms        Room[]
  
  @@index([gameId])
  @@map("regions")
}

model EventTrigger {
  id               Int      @id @default(autoincrement())
  name             String
  description      String?
  entityType       String   @map("entity_type")
  entityId         Int?     @map("entity_id")
  eventType        String   @map("event_type")
  priority         Int      @default(0)
  enabled          Boolean  @default(true)
  maxExecutions    Int?     @map("max_executions")
  executionCount   Int      @default(0) @map("execution_count")
  cooldownSeconds  Int?     @map("cooldown_seconds")
  lastExecuted     DateTime? @map("last_executed")
  createdAt        DateTime @default(now()) @map("created_at")
  
  conditions       TriggerCondition[]
  effects          TriggerEffect[]
  history          TriggerHistory[]
  statusEffects    CharacterStatusEffect[]
  
  @@map("event_triggers")
}

model TriggerCondition {
  id                 Int      @id @default(autoincrement())
  triggerId          Int      @map("trigger_id")
  conditionOrder     Int      @default(0) @map("condition_order")
  conditionType      String   @map("condition_type")
  comparisonOperator String?  @map("comparison_operator")
  conditionValue     String   @map("condition_value")
  logicOperator      String   @default("AND") @map("logic_operator")
  createdAt          DateTime @default(now()) @map("created_at")
  
  trigger            EventTrigger @relation(fields: [triggerId], references: [id], onDelete: Cascade)
  
  @@map("trigger_conditions")
}

model TriggerEffect {
  id               Int      @id @default(autoincrement())
  triggerId        Int      @map("trigger_id")
  effectOrder      Int      @default(0) @map("effect_order")
  effectType       String   @map("effect_type")
  targetType       String   @map("target_type")
  targetSpecifier  String?  @map("target_specifier")
  effectData       String   @map("effect_data")
  delaySeconds     Int      @default(0) @map("delay_seconds")
  durationSeconds  Int?     @map("duration_seconds")
  message          String?
  createdAt        DateTime @default(now()) @map("created_at")
  
  trigger          EventTrigger @relation(fields: [triggerId], references: [id], onDelete: Cascade)
  
  @@map("trigger_effects")
}

model TriggerHistory {
  id              Int      @id @default(autoincrement())
  triggerId       Int      @map("trigger_id")
  characterId     Int?     @map("character_id")
  roomId          Int?     @map("room_id")
  eventType       String   @map("event_type")
  eventData       String?  @map("event_data")
  effectsApplied  String?  @map("effects_applied")
  executionTime   DateTime @default(now()) @map("execution_time")
  
  trigger         EventTrigger @relation(fields: [triggerId], references: [id], onDelete: Cascade)
  
  @@map("trigger_history")
}

model Item {
  id                  Int      @id @default(autoincrement())
  name                String
  description         String
  extendedDescription String?  @map("extended_description")
  type                String
  weight              Float    @default(0.0)
  value               Int      @default(0)
  stackable           Boolean  @default(false)
  maxStack            Int      @default(1) @map("max_stack")
  armorRating         Int?     @default(0) @map("armor_rating")
  equipmentSlot       String?  @map("equipment_slot")
  isFixed             Boolean  @default(false) @map("is_fixed")
  createdAt           DateTime @default(now()) @map("created_at")
  
  roomItems           RoomItem[]
  inventoryItems      CharacterInventory[]
  itemCurse           ItemCurse?
  
  @@map("items")
}

model Character {
  id                Int      @id @default(autoincrement())
  gameId            Int      @map("game_id")
  name              String
  description       String?
  type              String   @default("player")
  currentRoomId     Int?     @map("current_room_id")
  strength          Int      @default(10)
  dexterity         Int      @default(10)
  intelligence      Int      @default(10)
  constitution      Int      @default(10)
  wisdom            Int      @default(10)
  charisma          Int      @default(10)
  maxHealth         Int?     @map("max_health")
  currentHealth     Int?     @map("current_health")
  isHostile         Boolean  @default(false) @map("is_hostile")
  isDead            Boolean  @default(false) @map("is_dead")
  dialogueResponse  String?  @map("dialogue_response")
  createdAt         DateTime @default(now()) @map("created_at")
  
  game              Game     @relation(fields: [gameId], references: [id])
  inventory         CharacterInventory[]
  
  @@map("characters")
}

model CharacterInventory {
  id            Int      @id @default(autoincrement())
  characterId   Int      @map("character_id")
  itemId        Int      @map("item_id")
  quantity      Int      @default(1)
  equipped      Boolean  @default(false)
  equippedSlot  String?  @map("equipped_slot")
  createdAt     DateTime @default(now()) @map("created_at")
  
  character     Character @relation(fields: [characterId], references: [id])
  item          Item      @relation(fields: [itemId], references: [id])
  
  @@map("character_inventory")
}

model RoomItem {
  id         Int      @id @default(autoincrement())
  roomId     Int      @map("room_id")
  itemId     Int      @map("item_id")
  quantity   Int      @default(1)
  createdAt  DateTime @default(now()) @map("created_at")
  
  room       Room     @relation(fields: [roomId], references: [id])
  item       Item     @relation(fields: [itemId], references: [id])
  
  @@map("room_items")
}

model CharacterStatusEffect {
  id               Int      @id @default(autoincrement())
  characterId      Int      @map("character_id")
  statusType       String   @map("status_type")
  sourceTriggerId  Int?     @map("source_trigger_id")
  effectData       String?  @map("effect_data")
  expiresAt        DateTime? @map("expires_at")
  createdAt        DateTime @default(now()) @map("created_at")
  
  sourceTrigger    EventTrigger? @relation(fields: [sourceTriggerId], references: [id])
  
  @@map("character_status_effects")
}

model ItemCurse {
  id               Int      @id @default(autoincrement())
  itemId           Int      @unique @map("item_id")
  curseType        String   @map("curse_type")
  preventsActions  String   @map("prevents_actions")
  curseMessage     String   @map("curse_message")
  removalCondition String?  @map("removal_condition")
  createdAt        DateTime @default(now()) @map("created_at")
  
  item             Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  @@map("item_curses")
}

model ActionCondition {
  id              Int      @id @default(autoincrement())
  entityType      String   @map("entity_type")
  entityId        Int      @map("entity_id")
  actionType      String   @map("action_type")
  conditionType   String   @map("condition_type")
  conditionData   String?  @map("condition_data")
  failureMessage  String   @map("failure_message")
  hintMessage     String?  @map("hint_message")
  priority        Int      @default(0)
  createdAt       DateTime @default(now()) @map("created_at")
  
  @@map("action_conditions")
}