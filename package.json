{
  "name": "shadow_kingdom",
  "version": "1.0.0",
  "description": "Shadow Kingdom - Interactive TypeScript CLI",
  "main": "dist/index.js",
  "bin": {
    "shadow_kingdom": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:grok": "ts-node scripts/test-grok.ts",
    "test:bg": "ts-node scripts/test-background-generation.ts",
    "test:limits": "ts-node scripts/test-generation-limits.ts",
    "test:errors": "ts-node scripts/test-error-handling.ts",
    "test:tracking": "ts-node scripts/test-generation-tracking.ts",
    "test:nlp": "ts-node scripts/test-nlp-manual.ts",
    "test:nlp-phase2": "ts-node scripts/test-nlp-phase2.ts",
    "test:nlp-phase3": "ts-node scripts/test-nlp-phase3.ts"
  },
  "keywords": [
    "cli",
    "typescript",
    "interactive"
  ],
  "author": "Isaac Priestley",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.11",
    "@types/react": "^19.1.10",
    "@types/sqlite3": "^3.1.11",
    "glob": "^11.0.3",
    "jest": "^30.0.5",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@prisma/client": "^6.14.0",
    "axios": "^1.11.0",
    "dotenv": "^17.2.1",
    "ink": "^3.2.0",
    "ink-text-input": "^4.0.3",
    "prisma": "^6.14.0",
    "react": "^17.0.2",
    "readline": "^1.3.0",
    "sqlite3": "^5.1.7"
  }
}
