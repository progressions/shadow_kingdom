# Grok AI Configuration
GROK_API_KEY=your_grok_api_key_here
GROK_API_URL=https://api.x.ai/v1
GROK_MODEL=grok-3
# Use grok-3 for development ($3/1M input, $15/1M output)
# Use grok-4 for production (same pricing but more advanced)

# API Settings
GROK_MAX_TOKENS=500
GROK_TEMPERATURE=0.8
ENABLE_AI_GENERATION=true
AI_CONTENT_FILTER=true

# Rate Limiting
GROK_REQUESTS_PER_SECOND=1
GROK_REQUESTS_PER_HOUR=60

# Cost Management
GROK_MONTHLY_BUDGET=10.00
GROK_ALERT_THRESHOLD=8.00

# Generation Limits
MAX_ROOMS_PER_GAME=50
MAX_GENERATION_DEPTH=3
GENERATION_COOLDOWN_MS=10000

# Character Generation
AI_CHARACTER_GENERATION_ENABLED=true
AI_CHARACTER_GENERATION_RATE=0.3
MAX_CHARACTERS_PER_ROOM=2

# Development Settings
AI_MOCK_MODE=false
AI_DEBUG_LOGGING=false